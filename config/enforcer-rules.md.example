---
rules:

  # ---------------------------------------------------------------------------
  # 1. Analysis Framework Enforcement
  # ---------------------------------------------------------------------------
  - name: analysis-framework
    enabled: true
    priority: 10
    description: >
      Analysis questions must load the analysis-framework skill and knowledge
      base first. Bans bare, ungrounded analysis.
    triggers:
      keywords:
        - "analyze"
        - "evaluate"
        - "judge"
        - "predict"
        - "trend"
        - "interpret"
      mode: any
    conditions:
      require_tools:
        - name: skill_view
          args_contains: ["analysis-framework"]
        - name: skill_view
          args_contains: ["knowledge-base"]
    only_block_tools: []
    always_block: true
    block_message: >
      Analysis questions require loading analysis-framework + knowledge-base
      skills first.

  # ---------------------------------------------------------------------------
  # 2. Sensitive Command Guard
  # ---------------------------------------------------------------------------
  - name: sensitive-command
    enabled: true
    priority: 9
    description: >
      Destructive shell commands must be verified with --dry-run first.
    triggers:
      keywords:
        - "delete"
        - "uninstall"
        - "clear"
        - "rm"
        - "kill"
        - "shutdown"
        - "reboot"
      mode: any
    conditions:
      require_tools:
        - name: terminal
          args_contains: ["--dry-run"]
    only_block_tools:
      - terminal
    block_message: >
      Sensitive commands: verify with --dry-run before executing.

  # ---------------------------------------------------------------------------
  # 3. No Wheel Reinvention
  # ---------------------------------------------------------------------------
  - name: no-wheel-reinvent
    enabled: true
    priority: 8
    description: >
      Before creating new tools or projects, search for existing solutions first.
    triggers:
      keywords:
        - "create"
        - "new"
        - "build"
        - "implement"
        - "design"
      mode: any
    conditions:
      require_tools:
        - name: web_search
        - name: search_files
    only_block_tools:
      - write_file
      - skill_manage
    block_message: >
      Before creating new, search for existing solutions first: web_search.

  # ---------------------------------------------------------------------------
  # 4. Reasoning Force
  # ---------------------------------------------------------------------------
  - name: reasoning-force
    enabled: true
    priority: 10
    description: >
      Logic/constraint problems MUST use formal verification tools (Z3/Prolog).
    triggers:
      keywords:
        - "logic"
        - "constraint"
        - "matching"
        - "deduction"
      mode: any
    conditions:
      require_tools:
        - name: mcp_chiasmus_chiasmus_formalize
        - name: mcp_chiasmus_chiasmus_verify
    only_block_tools:
      - terminal
    block_message: >
      Logic problems: use formal verification tools instead of bare reasoning.

  # ---------------------------------------------------------------------------
  # 5. Memory Verification
  # ---------------------------------------------------------------------------
  - name: memory-verify
    enabled: true
    priority: 7
    description: >
      When referencing past conversation content, use session search to verify.
    triggers:
      keywords:
        - "earlier"
        - "previously"
        - "last time"
        - "we discussed"
      mode: any
    conditions:
      require_tools:
        - name: session_search
    only_block_tools:
      - terminal
      - write_file
    block_message: >
      Reference past conversations via session_search before making claims.

  # ---------------------------------------------------------------------------
  # 6. Multi-Step Throttle
  # ---------------------------------------------------------------------------
  - name: multi-step-throttle
    enabled: true
    priority: 10
    description: >
      After N consecutive tool calls, the agent must report progress.
    triggers: {}
    conditions:
      require_tools: []
    only_block_tools: []
    max_consecutive_calls: 3
    block_message: >
      Multi-step throttle: report progress to the user before continuing.

  # ---------------------------------------------------------------------------
  # 7. Transform: Emoji → Kaomoji
  # ---------------------------------------------------------------------------
  - name: emoji-transform
    enabled: true
    priority: 1
    description: >
      Transforms common emoji to kaomoji (text-based emoticons) in output.
    triggers: {}
    transform:
      mode: regex_replace
      mappings:
        - pattern: "😊"
          replacement: "(^_^)"
        - pattern: "😅"
          replacement: "(^_^;)"

  # ---------------------------------------------------------------------------
  # 8. Turn Warning
  # ---------------------------------------------------------------------------
  - name: context-turn-warning
    enabled: true
    priority: 1
    description: >
      Warns the user when conversation exceeds threshold turns.
    triggers: {}
    track_turns:
      warn_at: [30, 50, 70, 90]
      message: >
        ⚠️ Conversation at {turns} turns. Consider starting a fresh session.

routing_table: |
  ▸ **Domain Routing Table (example)**
  ▸ Life decisions → analysis-framework + knowledge-base
  ▸ Technical/code → agent-core-docs
  ▸ System admin → system-admin + infrastructure-tools
  ▸ Learning/study → learning-methods + flashcard-system
  ▸ News/current events → daily-briefing
  ▸ Pets/hobbies → direct response (no specialized skill)
  ▸ Unmatched → fallback to general agent
---
